{
  "version": 2,
  "installCommand": "npm install && npm --prefix web install",
  "buildCommand": "npm run build",
  "outputDirectory": "web/dist",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
